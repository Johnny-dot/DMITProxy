# Server
SERVER_PORT=3001
PROXY_DEBUG=false
# Optional proxy request body limit (MB), defaults to 2
# PROXY_MAX_BODY_MB=2
# Optional JSON body limit for /local APIs (MB), defaults to 1
# LOCAL_JSON_LIMIT_MB=1
# Keep TLS verification enabled by default.
# Set true only when you explicitly trust a self-signed upstream certificate.
# XUI_TLS_INSECURE_SKIP_VERIFY=false
# Optional comma-separated CORS allowlist. Empty = no CORS headers added.
# CORS_ORIGINS=https://admin.example.com,https://portal.example.com
LOG_TO_FILE=true
# LOG_FILE=./data/logs/proxydog-server.log
# LOG_MAX_MB=20

# Local admin account (for /local auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
# Defaults to true in production and false in development when not set.
# COOKIE_SECURE=true
# Auth rate limit for /local/auth/login|register|password-reset/*
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20
# User password reset token validity window in seconds (default 1800 = 30 min)
# PASSWORD_RESET_TTL_SECONDS=1800

# 3X-UI upstream
VITE_3XUI_SERVER=https://64.186.227.197:49675
VITE_3XUI_BASE_PATH=/s3Av3p0dGLYiXbkG59

# Subscription host used by /portal and admin subscription tools
VITE_SUB_URL=http://64.186.227.197:2096
# Optional explicit subscription template for non-/sub/ servers:
# VITE_SUB_URL_TEMPLATE=https://host:port/custom-path/{subId}

# Optional client download mirrors (VPS/CDN/private network)
# If VITE_CLIENT_DOWNLOAD_VPS_BASE_URL is set, default file names are appended:
# - v2rayN.zip / v2rayNG.apk / clash-verge.exe / hiddify.apk
# You can override per client with explicit URLs below.
# VITE_CLIENT_DOWNLOAD_VPS_BASE_URL=https://your-vps.example.com/downloads
# VITE_CLIENT_DOWNLOAD_VPS_V2RAYN_URL=
# VITE_CLIENT_DOWNLOAD_VPS_V2RAYNG_URL=
# VITE_CLIENT_DOWNLOAD_VPS_CLASH_VERGE_URL=
# VITE_CLIENT_DOWNLOAD_VPS_HIDDIFY_URL=
# VITE_CLIENT_DOWNLOAD_VPS_SHADOWROCKET_URL=

# Auto-provision 3X-UI client when invite registration succeeds
XUI_AUTO_CREATE_ON_REGISTER=true
XUI_ADMIN_USERNAME=your_3xui_admin_username
XUI_ADMIN_PASSWORD=your_3xui_admin_password

# Optional auto-provision defaults
# XUI_AUTO_INBOUND_ID=1
# XUI_AUTO_CLIENT_LIMIT_IP=0
# XUI_AUTO_CLIENT_TOTAL_GB=0
# XUI_AUTO_CLIENT_EXPIRY_DAYS=0
