{
  "name": "dmitproxy",
  "description": "3X-UI admin dashboard and invite-based user portal.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "server:watch": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "node --import tsx/esm server/index.ts",
    "pw:install": "playwright install chromium",
    "pw:flow": "tsx scripts/playwright/invite-onboarding.ts",
    "pw:flow:headed": "tsx scripts/playwright/invite-onboarding.ts --headed",
    "pw:flow:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/playwright/run-invite-onboarding.ps1",
    "pw:flow:local:headed": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/playwright/run-invite-onboarding.ps1 -Headed",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci:verify": "npm run test && npm run lint && npm run typecheck && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "undici": "^7.24.0",
    "vite": "^6.2.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1"
  }
}
